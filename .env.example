# Supabase (community answers — server uses URL + service role)
# Vercel integration often sets SUPABASE_URL; the app accepts that or NEXT_PUBLIC_SUPABASE_URL.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Optional: browser Supabase client
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# PayPal / Venmo (TipJar)
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# Stripe (Apple Pay / Google Pay — add Elements + intent route when ready)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Cash App ($cashtag without forcing https encoding issues)
NEXT_PUBLIC_CASH_APP_TAG=$yourtag

# Buttondown newsletter
BUTTONDOWN_API_KEY=

# Site
NEXT_PUBLIC_SITE_URL=https://localhost:3000
