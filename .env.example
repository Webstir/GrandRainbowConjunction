# Supabase (community answers — server uses URL + service role)
# Vercel integration often sets SUPABASE_URL; the app accepts that or NEXT_PUBLIC_SUPABASE_URL.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Optional: browser Supabase client
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# PayPal.me username for /tip (default: PayPalSimmons). No @ in the value.
# NEXT_PUBLIC_PAYPAL_ME_USERNAME=PayPalSimmons

# Buttondown newsletter
BUTTONDOWN_API_KEY=

# Site
NEXT_PUBLIC_SITE_URL=https://localhost:3000
